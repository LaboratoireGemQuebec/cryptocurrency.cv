{
  "name": "free-crypto-news-extension",
  "version": "3.0.0",
  "private": true,
  "description": "Free Crypto News — Breaking crypto headlines, sentiment indicators, and price alerts right in your browser.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.background.config.ts",
    "build:popup": "vite build",
    "build:background": "vite build --config vite.background.config.ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "pnpm run build && cd dist && zip -r ../free-crypto-news-extension.zip ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
